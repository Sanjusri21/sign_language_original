# Dependencies
node_modules/

# Production builds
dist/
dist-ssr/

# Environment variables
*.local
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor & OS files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backend uploads & outputs (ignore all generated media except .gitkeep)
backend/output/**/*
!backend/output/**/.gitkeep
backend/uploads/**/*
!backend/uploads/**/.gitkeep

# Python bytecode & cache
__pycache__/
*.py[cod]
*$py.class

